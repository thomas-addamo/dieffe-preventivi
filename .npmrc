# Layout node_modules "piatto" (come npm) invece dello store isolato di pnpm.
# Necessario per electron-builder: altrimenti le dipendenze transitive dei pacchetti
# runtime (es. fs-extra richiesto da electron-updater) non finiscono nell'app.asar
# e l'app desktop crasha all'avvio con "Cannot find module 'fs-extra'".
node-linker=hoisted
