{
  "name": "dieffe-preventivi",
  "version": "3.4.1",
  "private": true,
  "description": "Gestione preventivi edili — Dieffe Ristrutturazioni",
  "author": "Dieffe Ristrutturazioni <impresa.dieffe@gmail.com>",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "next dev -p 3847",
    "build": "next build",
    "start": "next start -p 3847",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "icons": "node scripts/gen-icons.mjs",
    "electron:compile": "tsc --project electron/tsconfig.json",
    "electron:dev": "pnpm electron:compile && concurrently \"pnpm dev\" \"wait-on http://localhost:3847 && electron .\"",
    "electron:build": "pnpm build && pnpm electron:compile && electron-builder",
    "electron:build:mac": "pnpm build && pnpm electron:compile && electron-builder --mac",
    "electron:build:win": "pnpm build && pnpm electron:compile && electron-builder --win",
    "electron:dist": "pnpm build && pnpm electron:compile && electron-builder --mac --win",
    "electron:icons": "electron-icon-builder --input=assets/icon.png --output=assets"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
